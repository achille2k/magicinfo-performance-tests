# ==========================================
# MagicInfo Performance Tests - Configuration
# ==========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# MagicInfo Server Connection
MAGICINFO_BASE_URL=http://your-magicinfo-server:7001
MAGICINFO_WS_URL=ws://your-magicinfo-server:7001

# Authentication Credentials
MAGICINFO_USERNAME=admin
MAGICINFO_PASSWORD=Admin1243!

# Test Configuration
VIRTUAL_USERS=200
TEST_DURATION=5m
RAMP_UP_DURATION=1m

# Thresholds
HTTP_REQ_DURATION_P95=2000
HTTP_REQ_FAILED_RATE=0.05
WS_CONNECTING_MAX=3000
